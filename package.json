{
  "name": "capstone-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "main": "main.ts",
  "scripts": {
    "start": "nodemon",
    "start:dev": "nodemon",
    "start:prod": "node dist/main",
    "build": "nest build",
    "script:schema-diff": "ts-node -r tsconfig-paths/register src/common/scripts/check-schema-diff.ts",
    "script:sync-local-db": "ts-node -r tsconfig-paths/register src/common/scripts/sync-local-db.ts",
    "script:analyze-excel": "ts-node -r tsconfig-paths/register src/common/scripts/analyze-excel.ts",
    "script:bulk-import-medicines": "ts-node -r tsconfig-paths/register src/common/scripts/bulk-import-medicines.ts",
    "script:convert-excel-to-csv": "ts-node -r tsconfig-paths/register src/common/scripts/convert-excel-to-csv.ts",
    "script:generate-encryption-key": "ts-node -r tsconfig-paths/register src/common/scripts/generate-encryption-key.ts",
    "script:check-seeders": "ts-node -r tsconfig-paths/register src/common/scripts/check-seeders.ts",
    "script:check-and-sync": "pnpm run script:schema-diff && pnpm run script:sync-local-db"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,js,json",
    "ignore": [
      "src/**/*.spec.ts",
      "src/**/*.test.ts",
      "node_modules",
      "dist"
    ],
    "exec": "ts-node -r tsconfig-paths/register src/main.ts",
    "env": {
      "NODE_ENV": "development"
    },
    "delay": 1000,
    "verbose": true,
    "legacyWatch": true
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/passport": "^3.0.2",
    "@fastify/secure-session": "^8.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.6",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "fastify": "^4.29.1",
    "mongoose": "^8.15.0",
    "nodemailer": "^7.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.6",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.19",
    "@types/nodemailer": "^7.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "xlsx": "^0.18.5"
  }
}