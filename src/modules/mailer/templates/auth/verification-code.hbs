          ><tr><td
                bgcolor='#BFE3F1'
                style='padding: 24px; border-radius:16px 16px 0 0; text-align: center;'
              ><table
                  role='presentation'
                  align='center'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                ><tr><td align='center' valign='middle'><img
                        src='https://res.cloudinary.com/dfdzphroa/image/upload/v1776137626/bonix-file/fyrzyw5wpvogynswbysx.jpg'
                        alt='Medicare Logo'
                        width='48'
                        height='48'
                        style='border-radius: 50%; display: block; object-fit: cover; border: 2px solid #FFFFFF;'
                      /></td><td
                      align='left'
                      valign='middle'
                      style='padding-left: 12px; font-family: Arial, Helvetica, sans-serif; font-size: 22px; line-height: 1; font-weight: bold; color: #0B1F2A; letter-spacing: 1px;'
                    >MEDICARE</td></tr></table></td></tr><tr><td
                height='1'
                bgcolor='#D4ECF6'
                style='line-height:1px; font-size:1px;'
              >&nbsp;</td></tr><tr><td
                bgcolor='#FFFFFF'
                style='padding:24px; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; text-align:left;'
              ><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:24px; line-height:1.6; color:#0F172A; font-weight:bold; text-align:center;'
                >Email Verification</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                >Dear{{#if displayName}}
                    <strong>{{displayName}}</strong>{{/if}},</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                >Thank you for registering with Medicare. Please use the
                  verification code below to verify your email address:</p><table
                  width='100%'
                  bgcolor='#EAF6FB'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style='border-left: 4px solid #6FBAD1; border-radius: 8px;'
                ><tr><td
                      style='padding:16px 20px; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#1D4ED8; text-align:left;'
                    ><p
                        style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:30px; line-height:1.6; color:#1D4ED8; font-weight:bold; font-style:italic; letter-spacing:2px; text-align:center;'
                      ><strong><em
                          >{{code}}</em></strong></p></td></tr></table><p
                  style='Margin:16px 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#64748B; font-weight:normal; text-align:left; font-style:italic;'
                >This code will expire in
                  <strong><em>15 minutes</em></strong>.</p><p
                  style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#64748B; font-weight:normal; text-align:left; font-style:italic;'
                >If you did not create an account with Medicare, please disregard
                  this message.</p></td></tr><tr><td
                height='1'
                bgcolor='#D4ECF6'
                style='line-height:1px; font-size:1px;'
              >&nbsp;</td></tr><tr><td
                bgcolor='#F7FCFF'
                style='padding: 18px; text-align: center; font-size: 12px; color: #64748B; font-family: Arial, Helvetica, sans-serif; border-radius:0 0 16px 16px;'
              ><p
                  style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#475569; font-weight:normal; text-align:center;'
                >© 2026 Medicare</p></td></tr></table></td></tr></table>
