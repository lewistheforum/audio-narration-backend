<html lang='en'>
  <head><meta charset='UTF-8' /><meta
      name='viewport'
      content='width=device-width, initial-scale=1.0'
    /><title>Password Reset Request - Bonix</title>
  </head>
  <body style='margin:0; padding:0; background-color:#F7FCFF;'><table
      width='100%'
      bgcolor='#F7FCFF'
      cellpadding='0'
      cellspacing='0'
      border='0'
    ><tr><td align='center' style='padding:24px 12px;'><table
            width='600'
            align='center'
            bgcolor='#FFFFFF'
            cellpadding='0'
            cellspacing='0'
            border='0'
            style='width:100%; max-width:600px; border:1px solid #D4ECF6; border-radius:16px; margin:auto; background-color:#FFFFFF;'
          ><tr><td
                bgcolor='#BFE3F1'
                style='padding: 24px; border-radius:16px 16px 0 0; text-align: center;'
              ><table
                  role='presentation'
                  align='center'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                ><tr><td align='center' valign='middle'><img
                        src='https://res.cloudinary.com/dvqgpblgc/image/upload/v1773742650/73dd731ae68368dd3192_q8js9t.jpg'
                        alt='Bonix Logo'
                        width='48'
                        height='48'
                        style='border-radius: 50%; display: block; object-fit: cover; border: 2px solid #FFFFFF;'
                      /></td><td
                      align='left'
                      valign='middle'
                      style='padding-left: 12px; font-family: Arial, Helvetica, sans-serif; font-size: 22px; line-height: 1; font-weight: bold; color: #0B1F2A; letter-spacing: 1px;'
                    >BONIX</td></tr></table></td></tr><tr><td
                height='1'
                bgcolor='#D4ECF6'
                style='line-height:1px; font-size:1px;'
              >&nbsp;</td></tr><tr><td
                bgcolor='#FFFFFF'
                style='padding:24px; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; text-align:left;'
              ><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:24px; line-height:1.6; color:#0F172A; font-weight:bold; text-align:center;'
                >Password Reset Request</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                >Dear{{#if displayName}}
                    <strong>{{displayName}}</strong>{{/if}},</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                >We received a request to reset the password for your{{#if
                    role
                  }} <strong>{{role}}</strong>{{/if}}
                  account. Please use the verification code below to proceed:</p><table
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style='margin:0 0 16px 0; border:1px solid #E2E8F0; border-radius:12px;'
                ><tr><td style='padding:16px 20px;'><table
                        width='100%'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                      ><tr><td
                            width='40%'
                            align='left'
                            style='padding: 12px 0; color: #64748B; font-family:Arial, Helvetica, sans-serif; font-size:14px; border-bottom:1px solid #E2E8F0;'
                          >Username</td><td
                            width='60%'
                            align='right'
                            style='padding: 12px 0; color: #0F172A; font-weight: bold; font-family:Arial, Helvetica, sans-serif; font-size:14px; border-bottom:1px solid #E2E8F0;'
                          >{{displayName}}</td></tr><tr><td
                            width='40%'
                            align='left'
                            style='padding: 12px 0; color: #64748B; font-family:Arial, Helvetica, sans-serif; font-size:14px;'
                          >Account Role</td><td
                            width='60%'
                            align='right'
                            style='padding: 12px 0; color: #0F172A; font-weight: bold; font-family:Arial, Helvetica, sans-serif; font-size:14px;'
                          >{{role}}</td></tr></table></td></tr></table><table
                  width='100%'
                  bgcolor='#EAF6FB'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style='border-left: 4px solid #6FBAD1; border-radius: 8px;'
                ><tr><td
                      style='padding:16px 20px; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#1D4ED8; text-align:left;'
                    ><p
                        style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:30px; line-height:1.6; color:#1D4ED8; font-weight:bold; font-style:italic; letter-spacing:2px; text-align:center;'
                      ><strong><em
                          >{{code}}</em></strong></p></td></tr></table><p
                  style='Margin:16px 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#64748B; font-weight:normal; text-align:left; font-style:italic;'
                >This code will expire in
                  <strong><em>15 minutes</em></strong>.</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#64748B; font-weight:bold; text-align:left; font-style:italic;'
                >If you did not request this password reset, please disregard
                  this message or contact support if you have concerns.</p><table
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style=''
                ><tr><td
                      style='padding:12px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; text-align:left;'
                    ><p
                        style='Margin:0 0 12px 0; font-family:Arial, Helvetica, sans-serif; font-size:18px; line-height:1.6; color:#475569; font-weight:bold; text-align:left;'
                      >Security Tips</p><table
                        width='100%'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                      ><tr><td
                            valign='top'
                            width='18'
                            style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:1.6; color:#1D4ED8;'
                          >•</td><td
                            valign='top'
                            style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569;'
                          >Never share your reset code with anyone</td></tr><tr
                        ><td
                            valign='top'
                            width='18'
                            style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:1.6; color:#1D4ED8;'
                          >•</td><td
                            valign='top'
                            style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569;'
                          >Bonix will never ask for your password by email</td></tr><tr
                        ><td
                            valign='top'
                            width='18'
                            style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:1.6; color:#1D4ED8;'
                          >•</td><td
                            valign='top'
                            style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569;'
                          >Use a strong, unique password for your account</td></tr></table></td></tr></table></td></tr><tr
            ><td
                height='1'
                bgcolor='#D4ECF6'
                style='line-height:1px; font-size:1px;'
              >&nbsp;</td></tr><tr><td
                bgcolor='#F7FCFF'
                style='padding: 18px; text-align: center; font-size: 12px; color: #64748B; font-family: Arial, Helvetica, sans-serif; border-radius:0 0 16px 16px;'
              ><p
                  style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#475569; font-weight:normal; text-align:center;'
                >© 2026 Bonix</p></td></tr></table></td></tr></table>
  </body>
</html>