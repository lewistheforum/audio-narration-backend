<html lang='en'>
  <head><meta charset='UTF-8' /><meta
      name='viewport'
      content='width=device-width, initial-scale=1.0'
    /><title>Appointment Reminder</title>
  </head>
  <body style='margin:0; padding:0; background-color:#F7FCFF;'><table
      width='100%'
      bgcolor='#F7FCFF'
      cellpadding='0'
      cellspacing='0'
      border='0'
    ><tr><td align='center' style='padding:24px 12px;'><table
            width='600'
            align='center'
            bgcolor='#FFFFFF'
            cellpadding='0'
            cellspacing='0'
            border='0'
            style='width:100%; max-width:600px; border:1px solid #D4ECF6; border-radius:16px; margin:auto; background-color:#FFFFFF;'
          ><tr><td
                bgcolor='#BFE3F1'
                style='padding: 24px; border-radius:16px 16px 0 0; text-align: center;'
              ><table
                  role='presentation'
                  align='center'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                ><tr><td align='center' valign='middle'><img
                        src='https://res.cloudinary.com/dvqgpblgc/image/upload/v1773742650/73dd731ae68368dd3192_q8js9t.jpg'
                        alt='Medicare Logo'
                        width='48'
                        height='48'
                        style='border-radius: 50%; display: block; object-fit: cover; border: 2px solid #FFFFFF;'
                      /></td><td
                      align='left'
                      valign='middle'
                      style='padding-left: 12px; font-family: Arial, Helvetica, sans-serif; font-size: 22px; line-height: 1; font-weight: bold; color: #0B1F2A; letter-spacing: 1px;'
                    >MEDICARE</td></tr></table></td></tr><tr><td
                height='1'
                bgcolor='#D4ECF6'
                style='line-height:1px; font-size:1px;'
              >&nbsp;</td></tr><tr><td
                bgcolor='#FFFFFF'
                style='padding:24px; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; text-align:left;'
              ><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:24px; line-height:1.6; color:#0F172A; font-weight:bold; text-align:center;'
                >Appointment Reminder</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                >Dear{{#if patientName}}
                    <strong>{{patientName}}</strong>{{/if}},</p><p
                  style='Margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                >This is a courteous reminder of your upcoming appointment with
                  <strong>{{clinicName}}</strong>.</p><table
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style=''
                ><tr><td
                      style='padding:12px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; text-align:left;'
                    ><p
                        style='Margin:0 0 12px 0; font-family:Arial, Helvetica, sans-serif; font-size:18px; line-height:1.6; color:#475569; font-weight:bold; text-align:left;'
                      >Appointment Details</p><table
                        width='100%'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                        style=''
                      ><tr><td
                            style='padding:12px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; text-align:left;'
                          ><table
                              width='100%'
                              cellpadding='0'
                              cellspacing='0'
                              border='0'
                            ><tr><td
                                  width='40%'
                                  align='left'
                                  valign='top'
                                  style='padding:12px 0; border-bottom:1px solid #D4ECF6; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#64748B; text-align:left;'
                                >Date and Time</td><td
                                  width='60%'
                                  align='right'
                                  valign='top'
                                  style='padding:12px 0 12px 4px; border-bottom:1px solid #D4ECF6; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#0F172A; font-weight:bold; text-align:right;'
                                ><strong
                                    style='color:#0F172A; font-size:14px; font-family:Arial, Helvetica, sans-serif;'
                                  ><em>{{appointmentHour}},
                                      {{appointmentDate}}</em></strong></td></tr><tr
                              ><td
                                  width='40%'
                                  align='left'
                                  valign='top'
                                  style='padding:12px 0; border-bottom:1px solid #D4ECF6; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#64748B; text-align:left;'
                                >Attending Doctor</td><td
                                  width='60%'
                                  align='right'
                                  valign='top'
                                  style='padding:12px 0 12px 4px; border-bottom:1px solid #D4ECF6; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#0F172A; font-weight:bold; text-align:right;'
                                ><strong
                                    style='color:#0F172A; font-size:14px; font-family:Arial, Helvetica, sans-serif;'
                                  ><em>{{doctorName}}{{#if
                                        doctorSpecialization
                                      }}
                                        -
                                        {{doctorSpecialization}}{{/if}}</em></strong></td></tr></table></td></tr></table><p
                        style='Margin:16px 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; font-weight:bold; text-align:left;'
                      >Scheduled Services</p><table
                        width='100%'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                      >{{#each services}}<tr><td
                              style='padding:0 0 8px 0; font-family: Arial, Helvetica, sans-serif; font-size: 14px; line-height: 1.6; color: #475569;'
                            >•
                              {{serviceName}}</td></tr>{{/each}}</table></td></tr></table><table
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style='margin-top:16px;'
                ><tr><td><table
                        width='100%'
                        bgcolor='#EAF6FB'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                        style='border-left: 4px solid #6FBAD1; border-radius: 8px;'
                      ><tr><td
                            style='padding:16px 20px; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; text-align:left;'
                          ><p
                              style='Margin:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; font-weight:bold; text-align:left;'
                            >Clinic Information</p><p
                              style='Margin:0 0 6px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                            ><strong>Address:</strong> {{clinicAddress}}</p><p
                              style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; font-weight:normal; text-align:left;'
                            ><strong>Hotline:</strong>
                              {{clinicPhone}}</p></td></tr></table></td></tr></table><table
                  width='100%'
                  cellpadding='0'
                  cellspacing='0'
                  border='0'
                  style='margin-top:16px;'
                ><tr><td><table
                        width='100%'
                        cellpadding='0'
                        cellspacing='0'
                        border='0'
                        style=''
                      ><tr><td
                            style='padding:12px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; text-align:left;'
                          ><p
                              style='Margin:0 0 12px 0; font-family:Arial, Helvetica, sans-serif; font-size:18px; line-height:1.6; color:#475569; font-weight:bold; text-align:left;'
                            >Preparation Guidance</p><table
                              width='100%'
                              cellpadding='0'
                              cellspacing='0'
                              border='0'
                            ><tr><td
                                  valign='top'
                                  width='18'
                                  style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:1.6; color:#1D4ED8;'
                                >•</td><td
                                  valign='top'
                                  style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569;'
                                >Please arrive at least
                                  <strong><em>15 minutes early</em></strong>
                                  to complete your check-in. If you do not
                                  check-in by the end of the day, your
                                  appointment will be canceled and no refund
                                  will be issued. If you have any issues, please
                                  contact the clinic for assistance.</td></tr><tr
                              ><td
                                  valign='top'
                                  width='18'
                                  style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:1.6; color:#1D4ED8;'
                                >•</td><td
                                  valign='top'
                                  style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569;'
                                >Please bring a valid personal identification
                                  document.</td></tr><tr><td
                                  valign='top'
                                  width='18'
                                  style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:16px; line-height:1.6; color:#1D4ED8;'
                                >•</td><td
                                  valign='top'
                                  style='padding:0 0 8px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569;'
                                >Please bring any previous test results, if
                                  available.</td></tr></table></td></tr></table></td></tr></table><p
                  style='Margin:16px 0 0 0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#475569; font-weight:normal; text-align:left; font-style:italic;'
                >If you need to reschedule or cancel your appointment, please
                  contact the clinic at your earliest convenience.</p></td></tr><tr
            ><td
                style='padding:0 24px 24px 24px; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:1.6; color:#475569;'
              ><p
                  style='Margin:0 0 6px 0; font-family:Arial, Helvetica, sans-serif; font-size:14px; line-height:1.6; color:#475569; font-weight:bold; text-align:center;'
                ><strong>{{clinicName}}</strong></p><p
                  style='Margin:0 0 6px 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:1.6; color:#475569; font-weight:normal; text-align:center;'
                >Hotline: {{clinicPhone}}</p><p
                  style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:1.6; color:#475569; font-weight:normal; text-align:center;'
                >{{clinicAddress}}</p></td></tr><tr><td
                height='1'
                bgcolor='#D4ECF6'
                style='line-height:1px; font-size:1px;'
              >&nbsp;</td></tr><tr><td
                bgcolor='#F7FCFF'
                style='padding: 18px; text-align: center; font-size: 12px; color: #64748B; font-family: Arial, Helvetica, sans-serif; border-radius:0 0 16px 16px;'
              ><p
                  style='Margin:0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:1.6; color:#475569; font-weight:normal; text-align:center;'
                >© 2026 Medicare</p></td></tr></table></td></tr></table>
  </body>
</html>