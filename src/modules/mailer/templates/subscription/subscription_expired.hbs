<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Subscription Expired</title>
</head>

<body style="margin: 0; padding: 0; background-color: #F7FCFF; font-family: Arial, sans-serif;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <!-- Logo -->
        <div style="text-align: center; margin-bottom: 30px;">
            <img alt="Bonix Logo" style="width: 150px; height: auto;"
                src="https://res.cloudinary.com/dx1ejni0o/image/upload/v1758100904/crypto/ikz8lyq7dmaesm8atpxh.png" />
        </div>

        <!-- Main Content -->
        <div style="background: #FEF2F2; border-radius: 10px; padding: 30px; border-left: 4px solid #DC2626;">
            <h1 style="color: #DC2626; margin: 0 0 20px 0; font-size: 24px;">
                ⚠️ Subscription Expired
            </h1>
            <p style="color: #0B1F2A; font-size: 16px; margin: 0 0 15px 0;">
                Hi <strong>{{clinicName}}</strong>,
            </p>
            <p style="color: #475569; font-size: 16px; margin: 0 0 20px 0;">
                Your Bonix subscription (<strong>{{planName}}</strong>) has expired as of
                <strong>{{expirationDate}}</strong>.
            </p>

            <!-- Services Box -->
            <div
                style="background: white; border-radius: 8px; padding: 20px; margin: 20px 0; border: 2px solid #D4ECF6;">
                <h3 style="color: #DC2626; margin: 0 0 15px 0; font-size: 16px;">Services No Longer Available:</h3>
                <ul style="color: #64748B; font-size: 14px; margin: 0; padding-left: 20px;">
                    <li>Patient appointment management</li>
                    <li>Medical record access</li>
                    <li>Clinic dashboard features</li>
                    <li>Staff and doctor management</li>
                    <li>Reporting and analytics</li>
                </ul>
            </div>

            <!-- Alert Box -->
            <div
                style="background: #FEE2E2; border: 2px solid #DC2626; border-radius: 8px; padding: 15px; margin: 20px 0;">
                <p style="color: #991B1B; font-size: 14px; margin: 0; font-weight: 600;">
                    🔒 Your account is now in limited access mode. Renew to restore full functionality.
                </p>
            </div>

            <!-- CTA Button -->
            <div style="text-align: center; margin-top: 30px;">
                <a href="{{renewalLink}}"
                    style="background: #5CB6D3; color: white; padding: 14px 40px; text-decoration: none; border-radius: 6px; display: inline-block; font-weight: 600; font-size: 16px;">
                    Renew Subscription Now
                </a>
            </div>
        </div>

        <!-- Benefits Section -->
        <div style="background: #EAF6FB; border-radius: 8px; padding: 20px; margin-top: 20px;">
            <h3 style="color: #0B1F2A; margin: 0 0 10px 0; font-size: 16px;">Renew Today to:</h3>
            <ul style="color: #475569; font-size: 14px; margin: 10px 0; padding-left: 20px;">
                <li>Restore full access to all Bonix features</li>
                <li>Resume managing patient appointments</li>
                <li>Access your clinic data and reports</li>
                <li>Continue providing quality healthcare services</li>
            </ul>
        </div>

        <!-- Contact -->
        <div style="text-align: center; margin-top: 30px;">
            <p style="color: #64748B; font-size: 14px; margin: 0 0 10px 0;">
                Need assistance? Contact us at
                <a href="mailto:support@Bonix.com"
                    style="color: #1D4ED8; text-decoration: none;">support@Bonix.com</a>
            </p>
        </div>

        <!-- Footer -->
        <div style="text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #D4ECF6;">
            <p style="color: #64748B; font-size: 12px; margin: 0;">
                © 2026 Bonix. All rights reserved.
            </p>
        </div>
    </div>
</body>

</html>