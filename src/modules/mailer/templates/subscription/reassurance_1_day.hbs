<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Renewal Tomorrow</title>
</head>

<body style="margin: 0; padding: 0; background-color: #F7FCFF; font-family: Arial, sans-serif;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <!-- Logo -->
        <div style="text-align: center; margin-bottom: 30px;">
            <img alt="Medicare Logo" style="width: 150px; height: auto;"
                src="https://res.cloudinary.com/dx1ejni0o/image/upload/v1758100904/crypto/ikz8lyq7dmaesm8atpxh.png" />
        </div>

        <!-- Main Content -->
        <div style="background: #F0FDF4; border-radius: 10px; padding: 30px; border-left: 4px solid #10B981;">
            <h1 style="color: #10B981; margin: 0 0 20px 0; font-size: 24px;">
                ✅ Your Renewal is Scheduled
            </h1>
            <p style="color: #0B1F2A; font-size: 16px; margin: 0 0 15px 0;">
                Hi <strong>{{clinicName}}</strong>,
            </p>
            <p style="color: #475569; font-size: 16px; margin: 0 0 20px 0;">
                Good news! Your Medicare subscription renewal is already scheduled. No action needed from your side.
            </p>

            <!-- Details Box -->
            <div
                style="background: white; border-radius: 8px; padding: 20px; margin: 20px 0; border: 1px solid #D4ECF6;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <span style="color: #64748B; font-size: 14px;">Current Plan:</span>
                    <strong style="color: #0B1F2A; font-size: 16px;">{{currentPlan}}</strong>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                    <span style="color: #64748B; font-size: 14px;">Next Plan:</span>
                    <strong style="color: #10B981; font-size: 16px;">{{nextPlan}}</strong>
                </div>
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="color: #64748B; font-size: 14px;">Activates:</span>
                    <strong style="color: #059669; font-size: 16px;">Tomorrow at midnight</strong>
                </div>
            </div>

            <!-- Info Box -->
            <div style="background: #D1FAE5; border-left: 4px solid #10B981; padding: 15px; margin: 20px 0;">
                <p style="color: #065F46; font-size: 14px; margin: 0;">
                    🎉 <strong>Automatic Renewal:</strong> Your subscription will seamlessly continue with zero
                    downtime.
                </p>
            </div>

            <!-- CTA Button -->
            <div style="text-align: center; margin-top: 30px;">
                <a href="http://localhost:5173/subscription"
                    style="background: #5CB6D3; color: white; padding: 14px 40px; text-decoration: none; border-radius: 6px; display: inline-block; font-weight: 600; font-size: 16px;">
                    View Subscription Details
                </a>
            </div>
        </div>

        <!-- What's Next Section -->
        <div style="background: #EAF6FB; border-radius: 8px; padding: 20px; margin-top: 20px;">
            <h3 style="color: #0B1F2A; margin: 0 0 10px 0; font-size: 16px;">What Happens Next?</h3>
            <ul style="color: #475569; font-size: 14px; margin: 10px 0; padding-left: 20px;">
                <li>Your new subscription will activate automatically</li>
                <li>You'll continue to have uninterrupted access</li>
                <li>All your data and settings will remain intact</li>
                <li>We'll send you a confirmation once the renewal is complete</li>
            </ul>
        </div>

        <!-- Contact -->
        <div style="text-align: center; margin-top: 30px;">
            <p style="color: #64748B; font-size: 14px; margin: 0 0 10px 0;">
                Questions? Contact us at
                <a href="mailto:support@medicare.com"
                    style="color: #1D4ED8; text-decoration: none;">support@medicare.com</a>
            </p>
        </div>

        <!-- Footer -->
        <div style="text-align: center; margin-top: 30px; padding-top: 20px; border-top: 1px solid #D4ECF6;">
            <p style="color: #64748B; font-size: 12px; margin: 0;">
                © 2026 Medicare. All rights reserved.
            </p>
        </div>
    </div>
</body>

</html>