# Docker Compose Project Name
COMPOSE_PROJECT_NAME=medicare-backend

# Server Configuration
PORT=your-back-end-port
NODE_ENV=development
FRONTEND_URL=your-front-end-url

# JWT Configuration
JWT_SECRET=your-secret

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=mongo-database

# PostgreSQL Configuration
# For Docker Local: POSTGRES_HOST=localhost, POSTGRES_SSL=false
# For Aiven Production: POSTGRES_HOST=xxx.aivencloud.com, POSTGRES_SSL=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=medicare
POSTGRES_SSL=false

# Docker PostgreSQL Configuration (only for local development with Docker)
POSTGRES_VERSION=pg17-alpine
POSTGRES_CONTAINER_NAME=medicare_postgres

# Redis Configuration (for session management and caching)
# For Docker Local: REDIS_HOST=localhost
# For Production: REDIS_HOST=<your-redis-host>
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# Docker Redis Configuration (only for local development with Docker)
REDIS_CONTAINER_NAME=medicare_redis
REDIS_MAX_MEMORY=256mb

# GMAIL
EMAIL_USER="your-email@example.com"
MAIL_TO="your-email@example.com"
EMAIL_PASSWORD="your-email-password"


# GOOGLE OAUT2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_URL=google-login-url
GOOGLE_CALLBACK_URL=google-callback-url

# Data Encryption Configuration
# Generate a new key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-string-here

SIS_SIGNATURE_SECRET=super_secret_key_for_encrypting_private_keys

# Timezone Configuration
TZ=Asia/Ho_Chi_Minh
