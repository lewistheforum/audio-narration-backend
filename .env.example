# Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-secret

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=test_capstone

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=capstone_db
POSTGRES_SSL=false #true when in production environment

# GMAIL
EMAIL_USER="your-email@example.com"
MAIL_TO="your-email@example.com"
EMAIL_PASSWORD="your-email-password"


# GOOGLE OAUT2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_URL=http://localhost:4000/
GOOGLE_URL_CALLBACK=http://localhost:4000/api/auth/google/callback
